# ─────────────────────────────────────────────────────────────────────────────
# Nilmani Ceylon Tours — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# The canonical URL of your site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://nilmaniceylontours.com

# Node environment: development | production | test
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Docker Compose default: postgres://nilmani:nilmanipass@localhost:5432/nilmani
# Production: use a strong random password (e.g. openssl rand -base64 32)
DATABASE_URL=postgres://nilmani:CHANGE_ME@localhost:5432/nilmani

# ── Better Auth ───────────────────────────────────────────────────────────────
# Full URL of your app (same as NEXT_PUBLIC_SITE_URL but server-side)
BETTER_AUTH_URL=https://nilmaniceylontours.com

# Secret used to sign sessions — generate with: openssl rand -base64 64
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET

# ── Google OAuth (optional — social login) ────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://nilmaniceylontours.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_CHANGE_ME

# The "From" address for outgoing emails (must be a verified domain in Resend)
EMAIL_FROM=Nilmani Ceylon Tours <tours@nilmaniceylontours.com>

# Admin notification email — receives new booking + contact form submissions
ADMIN_EMAIL=roshan@nilmaniceylontours.com

# ── Sentry (error tracking) ───────────────────────────────────────────────────
# Get your DSN at: https://sentry.io — free tier covers this project
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── PII Encryption (AES-256-GCM) ─────────────────────────────────────────────
# 32-byte hex key for encrypting phone numbers and passport details
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PII_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Guide's WhatsApp number (international format, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=94XXXXXXXXX
